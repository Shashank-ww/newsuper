generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Contact {
  id        String   @id @default(cuid())
  name      String?
  email     String
  contact   String
  message   String
  industry  String?
  createdAt DateTime @default(now())

  @@map("ClientReach")
}
